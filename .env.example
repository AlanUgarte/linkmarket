# ============================================================
# GOOGLE SHEETS (obligatorio)
# ============================================================
# La planilla debe estar compartida como "Cualquier persona con el
# enlace: Lector". No hace falta Google Cloud ni credenciales.
#
# ID de tu planilla. Lo sacás de la URL:
# https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
GOOGLE_SHEET_ID=

# gid de la pestaña (hoja) donde están tus productos. Está en la URL
# de la planilla: ...edit#gid=ESTE_NUMERO (la primera pestaña es 0).
GOOGLE_SHEET_GID=0

# ============================================================
# SITIO (obligatorio para SEO correcto)
# ============================================================
NEXT_PUBLIC_SITE_URL=https://tusitio.vercel.app
NEXT_PUBLIC_SITE_NAME=LinkMarket
NEXT_PUBLIC_TWITTER_HANDLE=@tumarca

# Meta Pixel (Facebook/Instagram Ads). Opcional: si no lo seteás se usa el ID
# por defecto del código. Dejalo vacío para desactivar el pixel.
NEXT_PUBLIC_META_PIXEL_ID=1539880447631462

# ============================================================
# MERCADO LIBRE — precios en vivo (opcional, ver README 3b)
# ============================================================
# App de developers.mercadolibre.com.ar con Client Credentials
# y permiso "Publicación y sincronización: Lectura".
ML_CLIENT_ID=
# El secret cargalo directo en Vercel; no lo dejes en archivos compartidos.
ML_CLIENT_SECRET=

# ============================================================
# REVALIDACIÓN MANUAL (opcional pero recomendado)
# ============================================================
# Secreto para poder pegarle a /api/revalidate?secret=... y refrescar
# el sitio al instante después de editar el Google Sheet.
REVALIDATE_SECRET=elegi-un-secreto-largo-y-random
